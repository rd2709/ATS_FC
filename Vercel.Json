    "locale": "en-IN",
    "entities": ["clients", "candidates", "openings", "interviews", "invoices"],
    "googleSheets": {
      "sheetNames": {
        "clients": "Clients",
        "candidates": "Candidates",
        "openings": "Openings",
        "interviews": "Interviews",
        "invoices": "Invoices"
      },
      "syncUrl": "",
      "note": "Paste your Google Apps Script Web App URL into syncUrl to enable two-way sync."
    }
  },

  "config": {
    "billingModels": [
      "Retainer only",
      "Success fee only",
      "Retainer + Success fee"
    ],
    "companySizes": ["1–50", "51–200", "201–1000", "1000+"],
    "noticePeriods": ["Immediate", "15 days", "30 days", "45 days", "60 days", "90 days"],
    "candidateStages": [
      "Sourced",
      "Profile shared",
      "Interview scheduled",
      "Offer made",
      "Joined / Placed",
      "Rejected / On hold"
    ],
    "openingStatuses": ["Open", "On hold", "Closed"],
    "invoiceTypes": [
      "Retainer",
      "Success fee — % of CTC",
      "Success fee — flat amount"
    ],
    "invoiceStatuses": ["Raised", "Pending", "Paid", "Overdue"],
    "interviewRounds": [
      "Round 1 — HR",
      "Round 2 — Technical",
      "Round 3 — Managerial",
      "Salary discussion"
    ],
    "interviewModes": ["Google Meet", "In-person", "Phone call"],
    "interviewDurations": ["30 min", "45 min", "1 hour", "90 min"],
    "defaultFeePercent": 8.33,
    "industries": [
      "IT", "BFSI", "FMCG", "Healthcare", "E-commerce",
      "Manufacturing", "Consulting", "EdTech", "Fintech", "Logistics"
    ]
  },

  "schemas": {
    "client": {
      "id": "string — unique, prefix CLI, e.g. CLI1715000000000",
      "company": "string — company/org name (required)",
      "contact": "string — primary contact person name",
      "email": "string — primary email address",
      "phone": "string — contact phone number",
      "billingModel": "string — one of config.billingModels",
      "retainer": "number — monthly retainer amount in INR",
      "billingDate": "number — day of month retainer is due (1–31)",
      "industry": "string — industry vertical",
      "size": "string — one of config.companySizes",
      "start": "string — contract start date (YYYY-MM-DD)",
      "end": "string — contract end date (YYYY-MM-DD)"
    },
    "candidate": {
      "id": "string — unique, prefix CA, e.g. CA1715000000000",
      "name": "string — full name (required)",
      "company": "string — current employer",
      "email": "string — email address",
      "phone": "string — phone number",
      "ctc": "number — current CTC in LPA",
      "exp": "number — total years of experience",
      "notice": "string — one of config.noticePeriods",
      "avail": "string — available-from date (YYYY-MM-DD)",
      "skills": "string — comma-separated skill list",
      "clientId": "string — foreign key → client.id",
      "role": "string — role being considered for",
      "stage": "string — one of config.candidateStages"
    },
    "opening": {
      "id": "string — unique, prefix OP, e.g. OP1715000000000",
      "clientId": "string — foreign key → client.id (required)",
      "title": "string — job title (required)",
      "positions": "number — number of open seats",
      "ctc": "string — target CTC range in LPA, e.g. '18–22'",
      "date": "string — date opened (YYYY-MM-DD)",
      "jd": "string — job description / key responsibilities",
      "status": "string — one of config.openingStatuses"
    },
    "interview": {
      "id": "string — unique, prefix IV, e.g. IV1715000000000",
      "candidateId": "string — foreign key → candidate.id",
      "clientId": "string — foreign key → client.id",
      "role": "string — role being interviewed for",
      "round": "string — one of config.interviewRounds",
      "date": "string — interview date (YYYY-MM-DD)",
      "time": "string — interview time (HH:MM, 24h)",
      "duration": "string — one of config.interviewDurations",
      "mode": "string — one of config.interviewModes",
      "candidateEmail": "string — candidate's email for invite",
      "interviewerEmail": "string — interviewer's email for invite",
      "status": "string — Scheduled | Completed | Cancelled | Rescheduled",
      "feedback": "string — post-interview notes"
    },
    "invoice": {
      "id": "string — unique, prefix INV, e.g. INV1715000000000",
      "clientId": "string — foreign key → client.id (required)",
      "clientName": "string — denormalized client company name",
      "type": "string — one of config.invoiceTypes",
      "candId": "string — foreign key → candidate.id (for success fee invoices)",
      "candName": "string — denormalized candidate name",
      "amount": "number — invoice amount in INR",
      "date": "string — invoice raised date (YYYY-MM-DD)",
      "dueDate": "string — payment due date (YYYY-MM-DD)",
      "status": "string — one of config.invoiceStatuses",
      "notes": "string — any reference or remarks",
      "pct": "number — fee percentage (for % of CTC type)",
      "ctc": "number — placed CTC in LPA (for % of CTC type)"
    }
  },

