{
  "_meta": {
    "app": "First Connect CRM + ATS",
    "version": "3.0",
    "description": "Full deployment-ready data file for First Connect CRM+ATS portal. Contains all entity schemas, seed records, configuration, and Google Sheets column mappings.",
